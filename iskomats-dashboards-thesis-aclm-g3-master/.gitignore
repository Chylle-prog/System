# .gitignore for iskomats-dashboards-thesis-aclm-g3-master

# Dependency directories
node_modules/

# Environment files
.env
.env.local

# Build outputs
dist/
dist-ssr/
*.local

# Editor directories
.vscode/

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Dashboard reference files
iskomats-admins/src/Pages/Dash/*-ref.jsx
iskomats-admins/references/

# Local Verification Training Data (Do NOT commit to production)
knowledge/
**/knowledge/
*.png_profile
*.png_fake

# OAuth2 / Gmail API Local Files
generate_token.py
client_secret.json

